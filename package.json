{
  "name": "smart-fashion-assistant",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "netlify/functions/*"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "preview:frontend": "cd frontend && npm run preview",
    "dev:functions": "netlify dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:functions\"",
    "build": "npm run build:frontend",
    "preview": "npm run preview:frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "netlify-cli": "^17.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}